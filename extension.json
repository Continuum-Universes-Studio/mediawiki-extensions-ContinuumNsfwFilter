{
  "name": "NSFW Filter",
  "version": "2.3.0",
  "author": "OnikaGPT 4o, Christian Daniel Jensen, ChatGPT-5.2",
  "url": "https://www.mediawiki.org/wiki/Extension:NSFW_Filter",
  "license-name": "GPL-3.0-or-later",
  "descriptionmsg": "nsfwblur-desc",
  "type": "other",
  "manifest_version": 2,
  "requires": {
    "MediaWiki": ">= 1.45.0"
  },
  "config": {
    "NsfwFilterPlaceholderImage": {
      "value": "NSFW-Placeholder.png",
      "path": false,
      "description": "File title used as the server-side placeholder for NSFW files requested through the NsfwFilter proxy endpoint by viewers who are not allowed to see the original media.",
      "public": false
    }
  },
  "AutoloadClasses": {
    "NsfwFilter\\Hooks": "includes/Hooks.php"
  },
  "MessagesDirs": {
    "NsfwFilter": [
      "i18n"
    ]
  },
  "AvailableRights": [
    "nsfw-unblur"
  ],
  "GroupPermissions": {
    "adultreader": {
      "nsfw-unblur": true
    },
    "sysop": {
      "nsfw-unblur": true
    },
    "loremaster-supreme": {
      "nsfw-unblur": true
    },
    "grand-forgemaster": {
      "nsfw-unblur": true
    }
  },
  "DefaultUserOptions": {
    "nsfwblurred": 0
  },
    "Hooks": {
        "BeforePageDisplay": "NsfwFilter\\Hooks::onBeforePageDisplay",
        "OutputPageBeforeHTML": "NsfwFilter\\Hooks::onOutputPageBeforeHTML",
        "ThumbnailBeforeProduceHTML": "NsfwFilter\\Hooks::onThumbnailBeforeProduceHTML",
        "OutputPageParserOutput": "NsfwFilter\\Hooks::onOutputPageParserOutput",
        "OutputPageParserOutputComplete": "NsfwFilter\\Hooks::onOutputPageParserOutputComplete",

        "ParserOutput": "NsfwFilter\\Hooks::onParserOutput",

        "SpecialPageBeforeExecute": "NsfwFilter\\Hooks::onSpecialPageBeforeExecute",
        "SpecialSearchResultsAppend": "NsfwFilter\\Hooks::onSpecialSearchResultsAppend",
        "SearchResultProvideThumbnail": "NsfwFilter\\Hooks::onSearchResultProvideThumbnail",
        "ShowSearchHit": "NsfwFilter\\Hooks::onShowSearchHit",

        "ImageBeforeProduceHTML": "NsfwFilter\\Hooks::onImageBeforeProduceHTML",
        "ImagePageFindFile": "NsfwFilter\\Hooks::onImagePageFindFile",
        "ImgAuthModifyHeaders": "NsfwFilter\\Hooks::onImgAuthModifyHeaders",
        "GetPreferences": "NsfwFilter\\Hooks::onGetPreferences",

        "PageRenderingHash": "NsfwFilter\\Hooks::onPageRenderingHash",
        "UserGetDefaultOptions": "NsfwFilter\\Hooks::onUserGetDefaultOptions",
        "UserSaveOptions": "NsfwFilter\\Hooks::onUserSaveOptions"        
   }
        
}
